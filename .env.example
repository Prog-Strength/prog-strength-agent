# Anthropic API key — sk-ant-… from console.anthropic.com.
ANTHROPIC_API_KEY=replace-me

# HS256 secret shared with prog-strength-api. The agent verifies incoming
# user JWTs against this key. MUST match the value used by the API and
# the MCP server.
JWT_SIGNING_KEY=replace-me

# Where the MCP server lives. In prod, resolves over the shared docker
# network. In local dev, point at your locally-running MCP container or
# `uv run prog-strength-mcp` (port 8000 by default).
PROG_STRENGTH_MCP_URL=http://mcp:8000/mcp

# Bind address for the FastAPI server.
AGENT_HOST=0.0.0.0
AGENT_PORT=8001

# Claude model + per-turn output cap. Override to experiment with smaller
# models (claude-haiku-4-5-20251001, claude-sonnet-4-6) without code changes.
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=2048
